# 火山引擎 API 配置（方舟 Ark：model 填「推理接入点 ID」ep-xxx，不是接入点显示名）
VOLCENGINE_API_KEY=your-api-key-here
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_EMBEDDING_MODEL=ep-your-embedding-endpoint-id
# 主对话 / RAG 生成（如 Doubao-Seed-1.8）
VOLCENGINE_LLM_MODEL=ep-your-chat-endpoint-id
# 知识图谱三元组抽取（如 Doubao-Seed-2.0-mini，可与主模型分开计费）
GRAPH_EXTRACTION_MODEL=ep-your-graph-extraction-endpoint-id

# 数据库配置
DATABASE_URL=sqlite:///./data/knowledge_base.db

# Chroma 向量数据库
CHROMA_PERSIST_DIR=./chroma_data

# 文件上传配置（相对路径解析为 backend/uploads，请勿频繁改目录）
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=52428800

# 分块默认配置
DEFAULT_CHUNK_SIZE=500
DEFAULT_CHUNK_OVERLAP=50

# Mock 模式（API 不可用时的兜底方案）
LLM_MOCK_MODE=true

# Phase 2 检索 / CRAG 阈值（RRF 分数尺度约 0.01–0.16，勿设 0.2+）
CRAG_MIN_SCORE=0.06
CRAG_MIN_OVERLAP=0.10
RETRIEVAL_ABSTAIN_ENABLED=true
RETRIEVAL_ABSTAIN_MIN_SCORE=0.06
RETRIEVAL_ABSTAIN_MIN_OVERLAP=0.12
RETRIEVAL_ABSTAIN_MIN_SUBSTANTIVE=0.10
RETRIEVAL_ABSTAIN_MIN_ANCHOR=0.20

# Week 3 结构感知分块（新入库文档生效；已有 chunk 需重建索引）
STRUCTURED_CHUNKING_ENABLED=true
STRUCTURED_CHUNK_MAX_CHARS=800
STRUCTURED_CHUNK_MIN_CHARS=100

# Week 1 Cross-Encoder 二阶段重排 + 检索后过滤
CROSS_ENCODER_RERANK_ENABLED=true
CROSS_ENCODER_MODEL=BAAI/bge-reranker-v2-m3
CROSS_ENCODER_DEVICE=cpu
HYBRID_VECTOR_CANDIDATES=30
HYBRID_FTS_CANDIDATES=30
HYBRID_RRF_POOL_SIZE=30
POST_RETRIEVAL_MIN_SCORE=0.25
POST_RETRIEVAL_MAX_PER_DOCUMENT=2

# AI 对话「快速模式」：前端 Chat 页开关，请求体 fast_mode=true 时按请求覆盖（见 app/core/chat_runtime.py）
# 全局临时提速仍可改下面几项并重启 uvicorn（与前端开关二选一或叠加）
