# 火山引擎 API 配置（方舟 Ark：model 填「推理接入点 ID」ep-xxx，不是接入点显示名）
VOLCENGINE_API_KEY=your-api-key-here
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_EMBEDDING_MODEL=ep-your-embedding-endpoint-id
# 主对话 / RAG 生成（如 Doubao-Seed-1.8）
VOLCENGINE_LLM_MODEL=ep-your-chat-endpoint-id
# 知识图谱三元组抽取（如 Doubao-Seed-2.0-mini，可与主模型分开计费）
GRAPH_EXTRACTION_MODEL=ep-your-graph-extraction-endpoint-id

# 数据库配置
DATABASE_URL=sqlite:///./data/knowledge_base.db

# Chroma 向量数据库
CHROMA_PERSIST_DIR=./chroma_data

# 文件上传配置（相对路径解析为 backend/uploads，请勿频繁改目录）
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=52428800

# 分块默认配置
DEFAULT_CHUNK_SIZE=500
DEFAULT_CHUNK_OVERLAP=50

# Mock 模式（API 不可用时的兜底方案）
LLM_MOCK_MODE=true
